<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E3F2FD"
    tools:context=".CreateItineraryActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            app:tint="#333333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="你想去哪里?"
            android:textColor="#333333"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- 目的地输入框 -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:boxBackgroundColor="@android:color/white"
            app:boxCornerRadiusBottomEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusTopStart="24dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_destination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:hint="输入目的地"
                android:textColor="#333333"
                android:textColorHint="#999999" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 出发日期 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="出发日期"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:boxBackgroundColor="@android:color/white"
            app:boxCornerRadiusBottomEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusTopStart="24dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_departure_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_itinerary"
                android:drawablePadding="8dp"
                android:hint="选择出发日期"
                android:textColor="#333333"
                android:textColorHint="#999999"
                android:focusable="false"
                android:clickable="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 返程日期 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="返程日期"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:boxBackgroundColor="@android:color/white"
            app:boxCornerRadiusBottomEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusTopStart="24dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_end_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_itinerary"
                android:drawablePadding="8dp"
                android:hint="选择返程日期"
                android:textColor="#333333"
                android:textColorHint="#999999"
                android:focusable="false"
                android:clickable="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 旅行偏好 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="旅行偏好"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold" />

        <GridLayout
            android:id="@+id/gl_preferences"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:columnCount="3"
            android:useDefaultMargins="true">

            <!-- 优化：增加了 checkedIcon 样式 -->
            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="📍 经典必玩"
                android:textSize="11sp"
                android:textColor="#333333"
                android:checkable="true"
                app:chipBackgroundColor="@color/white"
                app:chipIconVisible="false"
                app:checkedIconVisible="true"
                app:chipStrokeColor="#BBDEFB" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="🍽️ 吃吃喝喝"
                android:textSize="11sp"
                android:textColor="#333333"
                android:checkable="true"
                app:chipBackgroundColor="@color/white"
                app:checkedIconVisible="true"
                app:chipStrokeColor="#BBDEFB" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="🕵️ 小众探索"
                android:textSize="11sp"
                android:textColor="#333333"
                android:checkable="true"
                app:chipBackgroundColor="@color/white"
                app:checkedIconVisible="true"
                app:chipStrokeColor="#BBDEFB" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="📸 拍照出片"
                android:textSize="11sp"
                android:textColor="#333333"
                android:checkable="true"
                app:chipBackgroundColor="@color/white"
                app:checkedIconVisible="true"
                app:chipStrokeColor="#BBDEFB" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="🛍️ 逛街购物"
                android:textSize="11sp"
                android:textColor="#333333"
                android:checkable="true"
                app:chipBackgroundColor="@color/white"
                app:checkedIconVisible="true"
                app:chipStrokeColor="#BBDEFB" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="🏃 citywalk"
                android:textSize="11sp"
                android:textColor="#333333"
                android:checkable="true"
                app:chipBackgroundColor="@color/white"
                app:checkedIconVisible="true"
                app:chipStrokeColor="#BBDEFB" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="🏞️ 自然风光"
                android:textSize="11sp"
                android:textColor="#333333"
                android:checkable="true"
                app:chipBackgroundColor="@color/white"
                app:checkedIconVisible="true"
                app:chipStrokeColor="#BBDEFB" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="🎨 文艺展览"
                android:textSize="11sp"
                android:textColor="#333333"
                android:checkable="true"
                app:chipBackgroundColor="@color/white"
                app:checkedIconVisible="true"
                app:chipStrokeColor="#BBDEFB" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="🏛️ 历史古建"
                android:textSize="11sp"
                android:textColor="#333333"
                android:checkable="true"
                app:chipBackgroundColor="@color/white"
                app:checkedIconVisible="true"
                app:chipStrokeColor="#BBDEFB" />

        </GridLayout>

        <!-- 创建按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_plan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:padding="12dp"
            android:text="创建我的规划"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>

